{
    "name": "padosoft/laravel-rebel-channel-bird",
    "description": "Bird (formerly MessageBird) provider for Laravel Rebel Channels: phone verification via the Bird Verify API (SMS), plain SMS delivery, and signed delivery-status webhooks. Part of padosoft/laravel-rebel-*.",
    "license": "MIT",
    "keywords": [
        "laravel",
        "authentication",
        "bird",
        "messagebird",
        "verify",
        "sms",
        "padosoft",
        "rebel"
    ],
    "homepage": "https://github.com/padosoft/laravel-rebel-channel-bird",
    "authors": [
        {
            "name": "Padosoft",
            "email": "support@padosoft.com",
            "homepage": "https://www.padosoft.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^12.0|^13.0",
        "illuminate/support": "^12.0|^13.0",
        "padosoft/laravel-rebel-core": "^0.1",
        "padosoft/laravel-rebel-channels": "^0.1",
        "spatie/laravel-package-tools": "^1.92"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^10.0|^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Padosoft\\Rebel\\Channel\\Bird\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Padosoft\\Rebel\\Channel\\Bird\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Padosoft\\Rebel\\Channel\\Bird\\RebelBirdServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "pest",
        "phpstan": "phpstan analyse --memory-limit=512M",
        "pint": "pint",
        "check": [
            "pint --test",
            "@phpstan",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
