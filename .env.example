# ============================================================================
# laravel-rebel-channel-bird — environment variables
# ============================================================================

# --- Bird credentials (from the Bird / MessageBird dashboard) ----------------
# Access key: Bird dashboard → Developers → API access (use a LIVE key in prod,
# a key prefixed with "test_" for the sandbox).
BIRD_ACCESS_KEY=your_live_access_key
# Originator: the sender id shown to the recipient. An alphanumeric sender id is
# max 11 chars (e.g. "MyApp"), or use an approved phone number you own.
BIRD_ORIGINATOR=MyApp
# Optional: workspace id for Bird's newer Channels API (not required by the legacy
# Verify/Messaging endpoints this package uses).
BIRD_WORKSPACE_ID=

# Auto-register the Bird provider into the Rebel Channels registry (needs BIRD_ACCESS_KEY).
REBEL_BIRD_REGISTER=true

# --- Delivery status webhook ------------------------------------------------
# Records Bird delivery receipts (delivered / failed / cost) into the Rebel audit
# trail. Configure a webhook subscription / status report URL in Bird pointing to:
#     https://<your-host>/rebel/bird/status
REBEL_BIRD_WEBHOOK=true
REBEL_BIRD_WEBHOOK_VALIDATE=true
# Signing key for the webhook subscription (Bird shows it when you create the
# subscription); required when REBEL_BIRD_WEBHOOK_VALIDATE=true.
BIRD_WEBHOOK_SIGNING_KEY=your_webhook_signing_key
REBEL_BIRD_WEBHOOK_PATH=rebel/bird/status

# --- Live test suite (opt-in: SENDS A REAL MESSAGE) -------------------------
# Set to 1 and provide a test phone to run tests/Live against the real API.
REBEL_BIRD_LIVE=0
BIRD_TEST_PHONE=+391234567890
